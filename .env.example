# Agent Dashboard Configuration
# Copy to .env and fill in values

# API authentication key (required in production, optional in dev mode)
# When set, all mutating API calls require X-Api-Key header
DASHBOARD_API_KEY=your-secret-key-here

# OpenClaw Gateway connection (required for chat relay)
OPENCLAW_GATEWAY_URL=wss://your-gateway-url
OPENCLAW_GATEWAY_TOKEN=your-gateway-token

# WebSocket origin allowlist (comma-separated, required when dev mode is off)
# Only these origins can connect to /ws/chat
DASH_ALLOWED_ORIGINS=https://your-dashboard-domain.com

# Dev mode: set to 1 to relax auth and origin checks (default: 0)
DASHBOARD_DEV_MODE=0

# State directory for persisting agent data (default: ./data)
DASHBOARD_STATE_DIR=./data
